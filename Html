        ::-webkit-scrollbar-thumb {
            background: #c1c1c1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a8a8a8;
        }
    </style>
</head>
<body>
    <div class="history-container">
        <!-- Заголовок -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card header-card">
                    <div class="card-body">
                        <h1 class="card-title mb-2">
                            <i class="bi bi-clock-history"></i> История запусков приложений
                        </h1>
                        <p class="card-text opacity-75 mb-0">
                            Просмотр и анализ всех запусков приложений с фильтрацией и сортировкой
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Основные фильтры -->
        <div class="row mb-3">
            <div class="col-12">
                <div class="filter-card">
                    <div class="row g-3">
                        <!-- Быстрые фильтры по времени -->
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Период:</label>
                            <div class="btn-group d-flex flex-wrap" role="group">
                                <a th:href="@{/history(period='all', sort=${sortField}, order=${sortOrder})}" 
                                   th:classappend="${period == 'all'} ? 'btn btn-primary btn-sm time-filter-btn active' : 'btn btn-outline-primary btn-sm time-filter-btn'">
                                    Все время
                                </a>
                                <a th:href="@{/history(period='hour', sort=${sortField}, order=${sortOrder})}" 
                                   th:classappend="${period == 'hour'} ? 'btn btn-primary btn-sm time-filter-btn active' : 'btn btn-outline-primary btn-sm time-filter-btn'">
                                    За час
                                </a>
                                <a th:href="@{/history(period='day', sort=${sortField}, order=${sortOrder})}" 
                                   th:classappend="${period == 'day'} ? 'btn btn-primary btn-sm time-filter-btn active' : 'btn btn-outline-primary btn-sm time-filter-btn'">
                                    За сутки
                                </a>
                                <a th:href="@{/history(period='week', sort=${sortField}, order=${sortOrder})}" 
                                   th:classappend="${period == 'week'} ? 'btn btn-primary btn-sm time-filter-btn active' : 'btn btn-outline-primary btn-sm time-filter-btn'">
                                    За неделю
                                </a>
                                <a th:href="@{/history(period='month', sort=${sortField}, order=${sortOrder})}" 
                                   th:classappend="${period == 'month'} ? 'btn btn-primary btn-sm time-filter-btn active' : 'btn btn-outline-primary btn-sm time-filter-btn'">
                                    За месяц
                                </a>
                            </div>
                        </div>
                        
                        <!-- Поиск -->
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Поиск по приложению:</label>
                            <div class="search-input">
                                <i class="bi bi-search"></i>
                                <input type="text" class="form-control" id="searchInput" 
                                       placeholder="Введите имя приложения..."
                                       th:value="${appName ?: ''}">
                            </div>
                        </div>
                        
                        <!-- Фильтр по серверу -->
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Сервер:</label>
                            <input type="text" class="form-control" id="serverFilter" 
                                   placeholder="Фильтр по серверу..."
                                   th:value="${serverName ?: ''}">
                        </div>
                        
                        <!-- Активные фильтры -->
                        <div th:if="${appName or serverName}" class="col-12 mt-2">
                            <div class="d-flex align-items-center">
                                <small class="me-2 fw-bold">Активные фильтры:</small>
                                <div>
                                    <th:block th:if="${appName}">
                                        <span class="filter-tag">
                                            Приложение: [[${appName}]]
                                            <span class="remove" onclick="removeFilter('appName')">×</span>
                                        </span>
                                    </th:block>
                                    <th:block th:if="${serverName}">
                                        <span class="filter-tag">
                                            Сервер: [[${serverName}]]
                                            <span class="remove" onclick="removeFilter('serverName')">×</span>
                                        </span>
                                    </th:block>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Управление сортировкой -->
        <div class="row mb-3">
            <div class="col-12">
                <div class="sort-controls">
                    <div class="row align-items-center">
                        <div class="col-md-4">
                            <label class="form-label fw-bold mb-0">Сортировать по:</label>
                            <select class="form-select form-select-sm" id="sortFieldSelect">
                                <option value="startDate" th:selected="${sortField == 'startDate'}">Дате запуска</option>
                                <option value="appName" th:selected="${sortField == 'appName'}">Имени приложения (А-Я)</option>
                                <option value="appNameDesc" th:selected="${sortField == 'appNameDesc'}">Имени приложения (Я-А)</option>
                                <option value="appType" th:selected="${sortField == 'appType'}">Типу приложения</option>
                                <option value="serverName" th:selected="${sortField == 'serverName'}">Серверу</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold mb-0">Порядок:</label>
                            <div class="btn-group w-100">
                                <button type="button" class="btn btn-sm" 
                                        th:classappend="${sortOrder == 'asc'} ? 'btn-primary' : 'btn-outline-primary'"
                                        onclick="setSortOrder('asc')">
                                    <i class="bi bi-sort-alpha-down"></i> По возрастанию
                                </button>
                                <button type="button" class="btn btn-sm" 
                                        th:classappend="${sortOrder == 'desc'} ? 'btn-primary' : 'btn-outline-primary'"
                                        onclick="setSortOrder('desc')">
                                    <i class="bi bi-sort-alpha-down-alt"></i> По убыванию
                                </button>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold mb-0">Показать:</label>
                            <select class="form-select form-select-sm items-per-page" id="itemsPerPage" onchange="applyFilters()">
                                <option value="10" th:selected="${pageSize == 10}">10 записей</option>
                                <option value="25" th:selected="${pageSize == 25}">25 записей</option>
                                <option value="50" th:selected="${pageSize == 50}">50 записей</option>
                                <option value="100" th:selected="${pageSize == 100}">100 записей</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button class="btn btn-primary w-100" onclick="applyFilters()">
                                <i class="bi bi-filter"></i> Применить
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Таблица истории -->
        <div class="row">
            <div class="col-12">
                <div class="table-container">
                    <div class="table-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-list-ul"></i> Записи запусков
                            <span class="badge bg-light text-dark ms-2" th:text="${total}"></span>
                        </h5>
                        <div class="text-light small">
                            <i class="bi bi-arrows-angle-expand"></i> Кликните на заголовок колонки для сортировки
                        </div>
                    </div>
                    
                    <div class="scroll-container">
                        <table class="table table-custom" id="historyTable">
                            <thead>
                                <tr>
                                    <th onclick="sortTable('startDate')" 
                                        th:classappend="${sortField == 'startDate'} ? 'sorted' + (${sortOrder == 'asc'} ? ' sorted-asc' : ' sorted-desc') : ''">
                                        Дата и время
                                        <span class="sort-indicator">
                                            <i class="bi bi-sort-down" th:if="${sortField == 'startDate' and sortOrder == 'desc'}"></i>
                                            <i class="bi bi-sort-up" th:if="${sortField == 'startDate' and sortOrder == 'asc'}"></i>
                                        </span>
                                    </th>
                                    <th onclick="sortTable('appName')" 
                                        th:classappend="${sortField == 'appName' or sortField == 'appNameDesc'} ? 'sorted' + (${sortOrder == 'asc'} ? ' sorted-asc' : ' sorted-desc') : ''">
                                        Приложение
                                        <span class="sort-indicator">
                                            <i class="bi bi-sort-alpha-down" th:if="${sortField == 'appName' and sortOrder == 'asc'}"></i>
                                            <i class="bi bi-sort-alpha-down-alt" th:if="${sortField == 'appNameDesc' or (sortField == 'appName' and sortOrder == 'desc')}"></i>
                                        </span>
                                    </th>
                                    <th onclick="sortTable('appType')" 
                                        th:classappend="${sortField == 'appType'} ? 'sorted' + (${sortOrder == 'asc'} ? ' sorted-asc' : ' sorted-desc') : ''">
                                        Тип
                                        <span class="sort-indicator">
                                            <i class="bi bi-filter" th:if="${sortField == 'appType'}"></i>
                                        </span>
                                    </th>
                                    <th onclick="sortTable('serverName')" 
                                        th:classappend="${sortField == 'serverName'} ? 'sorted' + (${sortOrder == 'asc'} ? ' sorted-asc' : ' sorted-desc') : ''">
                                        Сервер
                                        <span class="sort-indicator">
                                            <i class="bi bi-hdd" th:if="${sortField == 'serverName'}"></i>
                                        </span>
                                    </th>
                                    <th>Git информация</th>
                                    <th>JVM параметры</th>
                                    <th>Конфигурация</th>
                                </tr>
                            </thead>
                            <tbody id="tableBody">
                                <tr th:each="launch : ${history}">
                                    <td class="text-nowrap">
                                        <div class="fw-bold" th:text="${#temporals.format(launch.startDate, 'HH:mm')}"></div>
                                        <div class="small text-muted" th:text="${#temporals.format(launch.startDate, 'dd.MM.yyyy')}"></div>
                                    </td>
                                    <td>
                                        <a th:href="@{/history/app/{name}(name=${launch.appName})}" 
                                           class="text-decoration-none fw-bold text-primary">
                                            [[${launch.appName}]]
                                        </a>
                                    </td>
                                    <td>
                                        <span th:classappend="'badge ' + 
                                            ${launch.appType == 'service'} ? 'badge-service' :
                                            ${launch.appType == 'report'} ? 'badge-report' :
                                            ${launch.appType == 'web'} ? 'badge-web' : 'badge-other'"
                                            class="badge"
                                            th:text="${launch.appType}">
                                        </span>
                                    </td>
                                    <td>
                                        <span th:if="${launch.serverName}" 
                                              class="fw-medium"
                                              th:text="${launch.serverName}"></span>
                                        <span th:unless="${launch.serverName}" class="no-data">—</span>
                                    </td>
                                    <td>
                                        <div th:if="${launch.gitJson}">
                                            <button class="btn btn-sm btn-outline-secondary" 
                                                    onclick="showJsonModal(this)" 
                                                    th:data-json="${launch.gitJson}"
                                                    th:data-appname="${launch.appName}">
                                                <i class="bi bi-code-slash"></i> Показать JSON
                                            </button>
                                            <div class="json-preview mt-1 small text-muted" 
                                                 th:title="${launch.gitJson}"
                                                 th:text="${#strings.substring(launch.gitJson, 0, 40) + '...'}">
                                            </div>
                                        </div>
                                        <div th:unless="${launch.gitJson}">
                                            <span class="no-data">—</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div th:if="${launch.jvm}">
                                            <button class="btn btn-sm btn-outline-info" 
                                                    onclick="showTextModal(this)"
                                                    th:data-text="${launch.jvm}"
                                                    th:data-appname="${launch.appName}"
                                                    th:data-type="JVM">
                                                <i class="bi bi-gear"></i> Показать
                                            </button>
                                            <div class="json-preview mt-1 small text-muted" 
                                                 th:title="${launch.jvm}"
                                                 th:text="${#strings.substring(launch.jvm, 0, 30) + '...'}">
                                            </div>
                                        </div>
                                        <div th:unless="${launch.jvm}">
                                            <span class="no-data">—</span>
                                        </div>
                                    </td>
                                    <td>
                                        <small class="text-muted" th:text="${launch.appConfig ?: '—'}"></small>
                                    </td>
                                </tr>
                                <tr th:if="${#lists.isEmpty(history)}">
                                    <td colspan="7" class="text-center py-5">
                                        <div class="py-5">
                                            <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
                                            <h4 class="text-muted mb-2">Нет данных для отображения</h4>
                                            <p class="text-muted mb-0">Измените параметры фильтрации</p>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    
                    <!-- Пагинация и информация -->
                    <div class="pagination-controls">
                        <div>
                            <small class="text-muted">
                                Показано записей: <strong th:text="${history.size()}"></strong> из <strong th:text="${total}"></strong>
                            </small>
                        </div>
                        <div>
                            <a href="/" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-arrow-left"></i> Назад к списку приложений
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Модальное окно для JSON -->
    <div class="modal fade" id="jsonModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="jsonModalTitle">Git информация</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <pre style="margin: 0; padding: 15px; background-color: #f8f9fa; max-height: 500px; overflow-y: auto;"><code id="jsonContent" style="font-family: 'Monaco', 'Menlo', monospace; font-size: 13px;"></code></pre>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
                    <button type="button" class="btn btn-primary" onclick="copyToClipboard()">
                        <i class="bi bi-clipboard"></i> Копировать
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Модальное окно для текста -->
    <div class="modal fade" id="textModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="textModalTitle">JVM параметры</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <pre style="margin: 0; padding: 15px; background-color: #f8f9fa; max-height: 500px; overflow-y: auto;"><code id="textContent" style="font-family: 'Monaco', 'Menlo', monospace; font-size: 13px;"></code></pre>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
                    <button type="button" class="btn btn-primary" onclick="copyTextToClipboard()">
                        <i class="bi bi-clipboard"></i> Копировать
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Текущие параметры фильтрации
        let currentParams = {
            period: '[[${period}]]' || 'all',
            appName: '[[${appName}]]' || '',
            serverName: '[[${serverName}]]' || '',
            sortField: '[[${sortField}]]' || 'startDate',
            sortOrder: '[[${sortOrder}]]' || 'desc',
            pageSize: '[[${pageSize}]]' || 25
        };

        // Форматирование JSON
        function syntaxHighlight(json) {
            if (typeof json != 'string') {
                json = JSON.stringify(json, undefined, 2);
            }
            json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            return json.replace(
                /("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g,
                function (match) {
                    var cls = 'number';
                    if (/^"/.test(match)) {
                        if (/:$/.test(match)) {
                            cls = 'key';
                        } else {
                            cls = 'string';
                        }
                    } else if (/true|false/.test(match)) {
                        cls = 'boolean';
                    } else if (/null/.test(match)) {
                        cls = 'null';
                    }
                    return '<span class="' + cls + '">' + match + '</span>';
                }
            );
        }

        // Сортировка таблицы
        function sortTable(field) {
            let newOrder = 'asc';
            
            if (field === currentParams.sortField) {
                // Если сортируем по той же колонке, меняем порядок
                newOrder = currentParams.sortOrder === 'asc' ? 'desc' : 'asc';
            } else if (field === 'appName' && currentParams.sortField === 'appNameDesc') {
                // Специальная обработка для имени приложения
                newOrder = 'asc';
            } else if (field === 'appNameDesc') {
                // Обработка для обратной сортировки по имени
                field = 'appName';
                newOrder = 'desc';
            }
            
            currentParams.sortField = field;
            currentParams.sortOrder = newOrder;
            applyFilters();
        }

        // Установка порядка сортировки
        function setSortOrder(order) {
            currentParams.sortOrder = order;
            document.getElementById('sortFieldSelect').value = currentParams.sortField;
            applyFilters();
        }

        // Применение фильтров
        function applyFilters() {
            currentParams.period = '[[${period}]]' || 'all';
            currentParams.appName = document.getElementById('searchInput').value.trim();
            currentParams.serverName = document.getElementById('serverFilter').value.trim();
            currentParams.sortField = document.getElementById('sortFieldSelect').value;
            currentParams.pageSize = document.getElementById('itemsPerPage').value;
            
            buildAndNavigate();
        }

        // Построение URL и переход
        function buildAndNavigate() {
            let url = '/history?';
            let params = [];
            
            if (currentParams.period && currentParams.period !== 'all') {
                params.push('period=' + encodeURIComponent(currentParams.period));
            }
            
            if (currentParams.appName) {
                params.push('appName=' + encodeURIComponent(currentParams.appName));
            }
            
            if (currentParams.serverName) {
                params.push('serverName=' + encodeURIComponent(currentParams.serverName));
            }
            
            if (currentParams.sortField) {
                params.push('sort=' + encodeURIComponent(currentParams.sortField));
            }
            
            if (currentParams.sortOrder) {
                params.push('order=' + encodeURIComponent(currentParams.sortOrder));
            }
            
            if (currentParams.pageSize) {
                params.push('size=' + encodeURIComponent(currentParams.pageSize));
            }
            
            window.location.href = url + params.join('&');
        }

        // Удаление фильтра
        function removeFilter(filterName) {
            if (filterName === 'appName') {
                document.getElementById('searchInput').value = '';
            } else if (filterName === 'serverName') {
                document.getElementById('serverFilter').value = '';
            }
            applyFilters();
        }

        // Показать JSON в модальном окне
        function showJsonModal(button) {
            const jsonStr = button.getAttribute('data-json');
            const appName = button.getAttribute('data-appname');
            
            document.getElementById('jsonModalTitle').textContent = 'Git информация: ' + appName;
            
            try {
                const jsonObj = JSON.parse(jsonStr);
                const formattedJson = JSON.stringify(jsonObj, null, 2);
                const highlightedJson = syntaxHighlight(formattedJson);
                
                document.getElementById('jsonContent').innerHTML = highlightedJson;
                
                const modal = new bootstrap.Modal(document.getElementById('jsonModal'));
                modal.show();
                
            } catch (e) {
                document.getElementById('jsonContent').textContent = jsonStr;
                const modal = new bootstrap.Modal(document.getElementById('jsonModal'));
                modal.show();
            }
        }

        // Показать текст в модальном окне
        function showTextModal(button) {
            const text = button.getAttribute('data-text');
            const appName = button.getAttribute('data-appname');
            const type = button.getAttribute('data-type') || 'JVM';
            
            document.getElementById('textModalTitle').textContent = type + ' параметры: ' + appName;
            document.getElementById('textContent').textContent = text;
            
            const modal = new bootstrap.Modal(document.getElementById('textModal'));
            modal.show();
        }

        // Копирование в буфер обмена
        function copyToClipboard() {
            const text = document.getElementById('jsonContent').textContent;
            navigator.clipboard.writeText(text).then(() => {
                showToast('JSON скопирован в буфер обмена', 'success');
            });
        }

        function copyTextToClipboard() {
            const text = document.getElementById('textContent').textContent;
            navigator.clipboard.writeText(text).then(() => {
                showToast('Текст скопирован в буфер обмена', 'success');
            });
        }

        // Показать уведомление
        function showToast(message, type) {
            const toast = document.createElement('div');
            toast.className = `toast align-items-center text-bg-${type === 'success' ? 'success' : 'danger'} border-0`;
            toast.setAttribute('role', 'alert');
            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">${message}</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            `;
            
            document.body.appendChild(toast);
            const bsToast = new bootstrap.Toast(toast);
            bsToast.show();
            
            setTimeout(() => toast.remove(), 3000);
        }

        // Обработка нажатия Enter в полях поиска
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') applyFilters();
        });
        
        document.getElementById('serverFilter').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') applyFilters();
        });

        // Автообновление страницы каждые 2 минуты
        setTimeout(() => location.reload(), 120000);

        // Инициализация
        document.addEventListener('DOMContentLoaded', function() {
            // Устанавливаем значения в селекты
            document.getElementById('sortFieldSelect').value = currentParams.sortField;
            document.getElementById('itemsPerPage').value = currentParams.pageSize;
            
            // Фокус на поле поиска
            document.getElementById('searchInput').focus();
        });
    </script>
</body>
</html>



